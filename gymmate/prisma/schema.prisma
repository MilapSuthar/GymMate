// GymMate database schema
// Covers all 5 sections: Match, Help Board, Trainers, Nutrition, Exercise Library

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =====================
// USERS
// =====================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  provider     String   @default("credentials") // credentials | google | apple
  googleId     String?  @unique // legacy — kept for backward compat with existing rows
  firebaseUid  String?  @unique // Firebase UID, stable across providers (Google, Apple, etc.)
  name            String
  displayName     String?
  age             Int?
  // Authoritative source of age — set once at signup (18+ enforced server-side).
  // We keep the legacy `age` column for back-compat with profiles created before
  // the age gate; new code should read age via `getAge(dateOfBirth)`.
  dateOfBirth     DateTime?
  // Self-identified gender. Free-ish set: "male" | "female" | "non_binary" | "other".
  gender          String?
  // Comma-separated list of genders this user wants to see in discover.
  // Empty/null means "everyone". Example: "male,female".
  showMeGenders   String?
  // Age preference window for who the user wants to see. Null = no bound.
  minAgePref      Int?
  maxAgePref      Int?
  bio             String?
  photoUrl        String?
  gymId           String?
  gym             Gym?     @relation(fields: [gymId], references: [id])
  gymName         String?  // free-text gym (real Gym relation comes later)
  latitude        Float?
  longitude       Float?
  fcmToken        String?
  goals           String?  // legacy comma-separated (kept for backward compat)
  fitnessGoals    String?  // comma-separated: strength,cardio,weight-loss,muscle-gain,flexibility
  experienceLevel String?  // beginner | intermediate | advanced
  // Comma-separated `day_slot` tokens describing when the user is typically
  // at the gym, e.g. "mon_morning,wed_morning,fri_evening". 35 possible
  // values (7 days × 5 slots). Used by discover to compute overlap-based
  // ranking — the GymMate moat. Empty/null = "unknown" (no overlap signal).
  gymSchedule     String?
  // Daily-streak gamification. `streakCount` is the run of consecutive UTC
  // days the user has opened the app; `lastActiveOn` is the last day counted.
  streakCount     Int       @default(0)
  lastActiveOn    DateTime?
  photos          UserPhoto[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Match relations
  swipesGiven    Swipe[]   @relation("Swiper")
  swipesReceived Swipe[]   @relation("Swiped")
  matchesA       Match[]   @relation("UserA")
  matchesB       Match[]   @relation("UserB")
  messagesSent   Message[] @relation("MessageSender")

  // Help Board
  questions     Question[]
  answers       Answer[]
  questionLikes QuestionLike[]
  answerLikes   AnswerLike[]

  // Trainer side
  trainerProfile TrainerProfile?
  bookingsAsClient Booking[] @relation("ClientBookings")

  // Nutrition
  mealPlanPurchases MealPlanPurchase[]
  nutritionLogs     NutritionLog[]
  dietitianProfile  DietitianProfile?

  // Exercise
  workoutLogs WorkoutLog[]

  // Notifications
  notifications Notification[]

  // Safety — reports and blocks
  reportsSent     Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")
  blocksSent      Block[]  @relation("Blocker")
  blocksReceived  Block[]  @relation("Blocked")
}

// =====================
// SAFETY: REPORTS & BLOCKS
// =====================
model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  reportedId  String
  reported    User     @relation("Reported", fields: [reportedId], references: [id])
  reason      String   // free text or one of the canonical reason strings
  context     String?  // optional: matchId, questionId, messageId — JSON
  status      String   @default("open") // open | reviewing | resolved | dismissed
  createdAt   DateTime @default(now())

  @@index([reportedId])
  @@index([status, createdAt])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  // A blocker can only block the same user once.
  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "new_match" | "new_message" | "new_answer"
  title     String
  body      String
  data      String?  // JSON payload for deep linking (matchId, questionId, etc.)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// =====================
// GYMS
// =====================
model Gym {
  id        String   @id @default(cuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  users     User[]
  trainers  TrainerProfile[]
}

// =====================
// MATCH
// =====================
model Swipe {
  id         String   @id @default(cuid())
  swiperId   String
  swiper     User     @relation("Swiper", fields: [swiperId], references: [id])
  swipedId   String
  swiped     User     @relation("Swiped", fields: [swipedId], references: [id])
  liked      Boolean
  createdAt  DateTime @default(now())

  @@unique([swiperId, swipedId])
}

model Match {
  id        String    @id @default(cuid())
  userAId   String
  userA     User      @relation("UserA", fields: [userAId], references: [id])
  userBId   String
  userB     User      @relation("UserB", fields: [userBId], references: [id])
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([userAId, userBId])
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  senderId  String
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  content   String
  readAt    DateTime? // null until the recipient opens the chat
  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
  @@index([matchId, senderId, readAt])
}

// =====================
// HELP BOARD
// =====================
model Question {
  id        String         @id @default(cuid())
  authorId  String
  author    User           @relation(fields: [authorId], references: [id])
  title     String
  body      String
  tags      String?        // comma-separated
  answers   Answer[]
  likes     QuestionLike[]
  createdAt DateTime       @default(now())
}

model Answer {
  id         String       @id @default(cuid())
  questionId String
  question   Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  authorId   String
  author     User         @relation(fields: [authorId], references: [id])
  body       String
  likes      AnswerLike[]
  createdAt  DateTime     @default(now())
}

model QuestionLike {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([questionId, userId])
}

model AnswerLike {
  id        String   @id @default(cuid())
  answerId  String
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([answerId, userId])
}

// =====================
// TRAINERS
// =====================
model TrainerProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  gymId           String?
  gym             Gym?      @relation(fields: [gymId], references: [id])
  specialty       String
  bio             String?
  pricePerSession Float
  certifications  String?
  tags            String?   // comma-separated e.g. "Powerlifting,Weight Loss"
  verified        Boolean   @default(false)
  rating          Float?
  reviewCount     Int       @default(0)
  bookings        Booking[]
  createdAt       DateTime  @default(now())
}

model Booking {
  id              String         @id @default(cuid())
  clientId        String
  client          User           @relation("ClientBookings", fields: [clientId], references: [id])
  trainerId       String
  trainer         TrainerProfile @relation(fields: [trainerId], references: [id])
  scheduledAt     DateTime
  durationMins    Int?
  notes           String?
  status          String         @default("pending") // pending, confirmed, completed, cancelled
  paidAmount      Float
  paid            Boolean        @default(false)
  stripeSessionId String?
  createdAt       DateTime       @default(now())
}

// =====================
// NUTRITION
// =====================
model DietitianProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id])
  registrationId String
  bio           String?
  verified      Boolean    @default(false)
  mealPlans     MealPlan[]
}

model MealPlan {
  id             String             @id @default(cuid())
  dietitianId    String
  dietitian      DietitianProfile   @relation(fields: [dietitianId], references: [id])
  title          String
  description    String?
  caloriesPerDay Int
  proteinPerDay  Int?
  carbsPerDay    Int?
  fatsPerDay     Int?
  durationWeeks  Int?
  price          Float
  tags           String?
  purchases      MealPlanPurchase[]
  createdAt      DateTime           @default(now())
}

model MealPlanPurchase {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id])
  pricePaid  Float
  createdAt  DateTime @default(now())
}

model NutritionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  name      String?
  mealType  String?
  calories  Int
  protein   Float
  carbs     Float
  fats      Float
  notes     String?
  createdAt DateTime @default(now())
}

// =====================
// EXERCISE LIBRARY
// =====================
model Exercise {
  id          String       @id @default(cuid())
  name        String
  muscleGroup String       // chest, back, legs, shoulders, arms, core, cardio
  category    String       // push, pull, legs, cardio
  difficulty  String?      // beginner, intermediate, advanced
  equipment   String?
  description String?
  videoUrl    String?
  workoutSets WorkoutSet[]
}

model WorkoutLog {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  date      DateTime     @default(now())
  notes     String?
  sets      WorkoutSet[]
}

model WorkoutSet {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id])
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
  reps         Int
  weightKg     Float
  setNumber    Int
}

// =====================
// USER PHOTOS
// =====================
model UserPhoto {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}
