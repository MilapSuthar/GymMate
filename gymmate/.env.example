# =====================================================================
# GymMate environment variables — copy to .env (or .env.local) and fill in.
# =====================================================================

# --- Database -----------------------------------------------------------
# Dev uses SQLite. For production set this to a Postgres URL.
DATABASE_URL="file:./dev.db"

# --- JWT signing --------------------------------------------------------
# Long random strings (32+ chars). Rotate to force-revoke all sessions.
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"

# --- App URL ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Redis (optional) ---------------------------------------------------
# Token store for refresh tokens. Falls back to in-memory if unset
# (fine for dev — but tokens are wiped on every server restart).
# REDIS_URL="redis://localhost:6379"

# =====================================================================
# Firebase Auth — required for "Continue with Google" / "Continue with Apple"
# =====================================================================
# Set up at https://console.firebase.google.com/
#   1. Create / pick a project
#   2. Authentication → Sign-in method → enable Google (and Apple later)
#   3. Project settings → "Your apps" → add a Web app to get the SDK config
#   4. Project settings → Service accounts → Generate new private key (JSON)
#      → use the values from that JSON for the FIREBASE_* vars below

# --- Firebase Web SDK (frontend, exposed to the browser) ---------------
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Optional:
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

# --- Firebase Admin SDK (backend, secret) ------------------------------
# From the service account JSON. Keep PRIVATE_KEY's newlines as literal \n.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
