NODE_ENV=development
PORT=4000

# PostgreSQL (PostGIS)
DATABASE_URL=postgresql://gymmate:gymmate@localhost:5432/gymmate

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Google OAuth
GOOGLE_CLIENT_ID=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gymmate-photos
S3_ACCESS_KEY=gymmate
S3_SECRET_KEY=gymmate123
S3_FORCE_PATH_STYLE=true

# Firebase (Android push notifications)
# Paste the entire JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# APNs (iOS push notifications)
APNS_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# Twilio (SMS OTP — behind FEATURE_OTP flag)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Sentry
SENTRY_DSN=

# Feature flags
FEATURE_APPLE_AUTH=false
FEATURE_OTP=false
